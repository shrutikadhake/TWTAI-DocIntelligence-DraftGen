{
  "eval_id": 1,
  "eval_name": "eval-filename-only",
  "prompt": "Convert sample-doc.md to HTML",
  "assertions": [
    {"id": "has-doctype", "description": "File starts with <!DOCTYPE html>"},
    {"id": "has-meta-charset", "description": "Contains <meta charset=\"UTF-8\">"},
    {"id": "title-from-h1", "description": "<title>Payment Gateway API</title> present"},
    {"id": "h1-converted", "description": "<h1>Payment Gateway API</h1> exists"},
    {"id": "h2-converted", "description": "At least one <h2> tag exists"},
    {"id": "h3-converted", "description": "At least one <h3> tag exists"},
    {"id": "bold-converted", "description": "<strong> tag exists"},
    {"id": "fenced-code-block", "description": "<pre><code> block exists"},
    {"id": "table-structure", "description": "<table>, <thead>, <tbody>, <th>, <td> all present"},
    {"id": "bullet-list", "description": "<ul> and <li> tags exist"},
    {"id": "numbered-list", "description": "<ol> and <li> tags exist"},
    {"id": "blockquote-converted", "description": "<blockquote> tag exists"},
    {"id": "hr-converted", "description": "<hr> tag exists"},
    {"id": "image-converted", "description": "<img src= with placeholder URL present"},
    {"id": "links-converted", "description": "<a href= tags exist"},
    {"id": "no-css", "description": "No <style> tag or style= attribute present"},
    {"id": "output-filename", "description": "File saved as sample-doc.html"},
    {"id": "body-tag", "description": "<body> tag exists"}
  ]
}
